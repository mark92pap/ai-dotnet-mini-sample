{
  "openapi": "3.0.1",
  "info": {
    "title": "AiMiniSample API",
    "description": "A minimal .NET 8 Web API with CRUD operations using MediatR and Entity Framework Core",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5170",
      "description": "Development server (HTTP)"
    },
    {
      "url": "https://localhost:7285",
      "description": "Development server (HTTPS)"
    }
  ],
  "paths": {
    "/User": {
      "get": {
        "tags": ["User"],
        "summary": "Get all users",
        "operationId": "GetAllUsers",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserResponse"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["User"],
        "summary": "Create a new user",
        "operationId": "CreateUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/User/{id}": {
      "get": {
        "tags": ["User"],
        "summary": "Get a user by ID",
        "operationId": "GetUserById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the user"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "404": {
            "description": "Entity not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["User"],
        "summary": "Update a user",
        "operationId": "UpdateUser",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the user to update"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "404": {
            "description": "Entity not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["User"],
        "summary": "Delete a user",
        "operationId": "DeleteUser",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the user to delete"
          }
        ],
        "responses": {
          "204": {
            "description": "No Content - Successfully deleted"
          },
          "404": {
            "description": "Entity not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/Debug/clear-db": {
      "post": {
        "tags": ["Debug"],
        "summary": "Clear database",
        "operationId": "ClearDatabase",
        "responses": {
          "204": {
            "description": "No Content - All entities deleted successfully"
          },
          "404": {
            "description": "Error occurred",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/User/{id}/pet/{petId}": {
      "post": {
        "tags": ["Pet"],
        "summary": "Assign pet to user by ID",
        "operationId": "AssignPetToUser",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the user"
          },
          {
            "name": "petId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            },
            "description": "The ID of the pet from the pet store API"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "404": {
            "description": "Entity not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/User/{id}/pet": {
      "get": {
        "tags": ["Pet"],
        "summary": "Get all pets of a user",
        "operationId": "GetPetsOfUser",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the user"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PetResponse"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Entity not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/items": {
      "get": {
        "tags": ["StoreItem"],
        "summary": "Get all store items",
        "operationId": "GetAllStoreItems",
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by category"
          },
          {
            "name": "isActive",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Filter by active status"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/StoreItemResponse"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["StoreItem"],
        "summary": "Create a new store item",
        "operationId": "CreateStoreItem",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateStoreItemRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StoreItemResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/items/{id}": {
      "get": {
        "tags": ["StoreItem"],
        "summary": "Get a store item by ID",
        "operationId": "GetStoreItemById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The ID of the store item"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StoreItemResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["StoreItem"],
        "summary": "Update a store item",
        "operationId": "UpdateStoreItem",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The ID of the store item to update"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateStoreItemRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StoreItemResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["StoreItem"],
        "summary": "Delete (soft-disable) a store item",
        "operationId": "DeleteStoreItem",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The ID of the store item to delete"
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateUserRequest": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the user"
          },
          "name": {
            "type": "string",
            "description": "Name of the user"
          }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the user"
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier of the user"
          },
          "name": {
            "type": "string",
            "description": "Name of the user"
          },
          "pets": {
            "type": "array",
            "description": "List of pets associated with this user",
            "items": {
              "$ref": "#/components/schemas/PetResponse"
            }
          }
        }
      },
      "PetResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier of the pet"
          },
          "name": {
            "type": "string",
            "description": "Name of the pet"
          }
        }
      },
      "CreateStoreItemRequest": {
        "type": "object",
        "required": ["name", "description", "category", "price"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the store item"
          },
          "description": {
            "type": "string",
            "description": "Description of the store item"
          },
          "sku": {
            "type": "string",
            "description": "Stock Keeping Unit (optional)",
            "nullable": true
          },
          "category": {
            "type": "string",
            "description": "Category of the item"
          },
          "price": {
            "type": "number",
            "format": "decimal",
            "description": "Price of the item",
            "minimum": 0.01
          },
          "currency": {
            "type": "string",
            "description": "Currency code (default: USD)",
            "default": "USD"
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether the item is active",
            "default": true
          },
          "stockQuantity": {
            "type": "integer",
            "description": "Stock quantity (optional)",
            "nullable": true
          }
        }
      },
      "UpdateStoreItemRequest": {
        "type": "object",
        "required": ["name", "description", "category", "price"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the store item"
          },
          "description": {
            "type": "string",
            "description": "Description of the store item"
          },
          "sku": {
            "type": "string",
            "description": "Stock Keeping Unit (optional)",
            "nullable": true
          },
          "category": {
            "type": "string",
            "description": "Category of the item"
          },
          "price": {
            "type": "number",
            "format": "decimal",
            "description": "Price of the item",
            "minimum": 0.01
          },
          "currency": {
            "type": "string",
            "description": "Currency code"
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether the item is active"
          },
          "stockQuantity": {
            "type": "integer",
            "description": "Stock quantity (optional)",
            "nullable": true
          }
        }
      },
      "StoreItemResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier of the store item"
          },
          "name": {
            "type": "string",
            "description": "Name of the store item"
          },
          "description": {
            "type": "string",
            "description": "Description of the store item"
          },
          "sku": {
            "type": "string",
            "description": "Stock Keeping Unit",
            "nullable": true
          },
          "category": {
            "type": "string",
            "description": "Category of the item"
          },
          "price": {
            "type": "number",
            "format": "decimal",
            "description": "Price of the item"
          },
          "currency": {
            "type": "string",
            "description": "Currency code"
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether the item is active"
          },
          "stockQuantity": {
            "type": "integer",
            "description": "Stock quantity",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          }
        }
      }
    }
  }
}